# backend/.env.docker.example — copy to backend/.env.docker for
# docker-compose deployments.
#
# Session 16 (2026-04-21) — docker-compose.yml references
# ./backend/.env.docker as env_file. This template makes the required
# keys explicit so a fresh `docker compose up --build` doesn't fail
# with cryptic defaults.

# --- Database (DATABASE_URL comes from compose; override only if you
# bypass compose networking) ---
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db:5432/unt_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Postgres credentials (matched by the `db` service) ---
# No default — compose reads ${POSTGRES_PASSWORD} from the host env or
# a .env file at the repo root. Do NOT hardcode weak defaults here.
POSTGRES_USER=postgres
POSTGRES_DB=unt_platform
# POSTGRES_PASSWORD=  # set via host env, not this file

# --- Chat model provider (DashScope or OpenAI-compatible host) ---
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-v4
OPENAI_TIMEOUT=60

# --- Auth / crypto ---
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_TOKEN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- RAG knobs ---
# Session 13: explicit .env toggle. Defaults to False if unset, True
# when we want the cross-encoder pass on live traffic.
RAG_USE_RERANKER=true
RAG_USE_MULTILINGUAL=false

# --- Runtime ---
ENVIRONMENT=production
DEBUG=false
