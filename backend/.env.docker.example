# backend/.env.docker.example — copy to backend/.env (or backend/.env.docker)
# and fill in the values before running the backend.
#
# A docker-compose.yml is NOT shipped in this open-source snapshot; wire your
# own infra around the variables below. The file is named `.env.docker.example`
# for historical reasons — for a local `uvicorn ... --reload` workflow it works
# the same way (FastAPI loads it via pydantic-settings).

# --- Database -----------------------------------------------------------------
# Local non-docker default (uncomment to use a host-installed Postgres):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/unt_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Used only by tooling that creates the DB / role for you:
POSTGRES_USER=postgres
POSTGRES_DB=unt_platform
# POSTGRES_PASSWORD=   # set via host env, not this file

# --- Chat model provider ------------------------------------------------------
# Default routing assumes a DashScope (Alibaba) account: an OpenAI-compatible
# endpoint that accepts a `qwen-*` model. If you hold a real OpenAI key, flip
# OPENAI_BASE_URL to https://api.openai.com/v1 and OPENAI_MODEL to e.g. gpt-4o-mini.
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-v4
OPENAI_TIMEOUT=60

# Optional second provider used by services/openai_failover.py and OCR. When
# unset the failover chain shrinks; OCR falls back to OPENAI_API_KEY.
# DASHSCOPE_API_KEY=

# Optional override for the embedding provider; defaults to DashScope.
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# --- Auth / crypto ------------------------------------------------------------
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_TOKEN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS / security headers --------------------------------------------------
# Production refuses `*`. Comma-separated; matches scheme + host + optional port.
ALLOWED_ORIGINS=http://localhost:5174
ALLOWED_HOSTS=localhost,127.0.0.1
FORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=true

# Comma-separated allowlist for the admin / data-confidence dashboard.
RAG_ADMIN_EMAILS=

# --- RAG knobs ----------------------------------------------------------------
# Disabled by default — the public repo's vector_search defaults work without
# a separate rerank API. Set to true if you have DASHSCOPE_API_KEY set.
RAG_USE_RERANKER=false
RAG_USE_MULTILINGUAL=false

# --- Billing webhook ----------------------------------------------------------
# HMAC secret for billing-provider webhooks. Endpoints return 503 when unset.
# BILLING_WEBHOOK_SECRET=

# --- Runtime ------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
